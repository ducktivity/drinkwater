# Box runtime env for the drinkwater stack. Copy to `.env.prod` and fill it in; deploy/remote-deploy.sh ships it to the box as /opt/ducktivity/drinkwater/.env (mode 600), which compose auto-loads. Not consumed by CI — CI only migrates + builds; the box holds these values.

ENV=prod

# Structured logging. Optional — box defaults to info + json.
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry error tracking (getsentry DSN). Empty disables it.
SENTRY_DSN=

# Token verification. Drinkwater verifies (does not sign) tokens minted by the central identity service: it fetches identity's public keys from JWKS_URL, and AUTH_ISSUER must match the tokens' "iss" claim. No signing secret or email key lives here.
JWKS_URL=https://id.ducktvt.com/.well-known/jwks.json
AUTH_ISSUER=https://id.ducktvt.com

# App-role Neon string (least privilege, DML only). NOT the migrator role — CI runs migrations with the separate DATABASE_URL_MIGRATOR GitHub secret.
DATABASE_URL=
