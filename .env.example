# Copy to .env and fill in. docker-compose reads this file automatically.

# ---- Backend (app) ----
ENV=development                 # prod | staging | development; tags every log + Sentry event
LOG_LEVEL=info                  # debug | info | warn | error
LOG_FORMAT=json                 # json (prod) | text (local pretty output)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/drinkwater?sslmode=disable
SENTRY_DSN=                     # empty disables Sentry (no-op); set to your project DSN in prod

# ---- Cloudflare Tunnel (cloudflared only; the prod box's sole ingress) ----
CLOUDFLARE_TUNNEL_TOKEN=        # token from the named tunnel in Cloudflare Zero Trust (prod only; dev does not run the tunnel)

# ---- Log shipper (Vector only; the Go app never sees these) ----
BETTERSTACK_SOURCE_TOKEN=             # source's ingesting/source token from BetterStack
BETTERSTACK_INGEST_HOST=https://in.logs.betterstack.com   # your source's ingesting host
