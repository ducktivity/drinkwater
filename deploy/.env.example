ENV=prod

# Structured logging. Optional — box defaults to info + json.
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry error tracking (getsentry DSN). Empty disables it.
SENTRY_DSN=

# Token verification. Drinkwater verifies (does not sign) tokens minted by the central identity service: it fetches identity's public keys from JWKS_URL, and AUTH_ISSUER must match the tokens' "iss" claim.
JWKS_URL=https://id.ducktvt.com/.well-known/jwks.json
AUTH_ISSUER=https://id.ducktvt.com

# App-role Neon string (least privilege, DML only).
DATABASE_URL=
