{
    "openapi": "3.0.0",
    "info": {
        "description": "Local-first sync engine.",
        "title": "Drinkwater Sync API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/sync": {
            "post": {
                "description": "Pushes local changes (upserts) to the server and pulls remote changes (delta) made on other devices.",
                "tags": [
                    "sync"
                ],
                "summary": "Sync local water logs with the server",
                "parameters": [
                    {
                        "description": "ISO-8601 Timestamp of the client's last sync",
                        "name": "since",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/api.WaterLog"
                                }
                            }
                        }
                    },
                    "description": "Array of local water logs to sync",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful sync response containing delta changes",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/api.SyncResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server or database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "/"
        }
    ],
    "components": {
        "schemas": {
            "api.SyncResponse": {
                "type": "object",
                "required": [
                    "changes",
                    "server_time"
                ],
                "properties": {
                    "changes": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/api.WaterLog"
                        }
                    },
                    "server_time": {
                        "type": "string"
                    }
                }
            },
            "api.WaterLog": {
                "type": "object",
                "required": [
                    "amount_ml",
                    "id",
                    "is_deleted",
                    "logged_at"
                ],
                "properties": {
                    "amount_ml": {
                        "type": "integer"
                    },
                    "id": {
                        "type": "string"
                    },
                    "is_deleted": {
                        "type": "boolean"
                    },
                    "logged_at": {
                        "type": "string"
                    }
                }
            }
        }
    }
}