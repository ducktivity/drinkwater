{
    "openapi": "3.0.0",
    "info": {
        "description": "Local-first sync engine.",
        "title": "Drinkwater Sync API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/v1/auth/me": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns the account for the supplied bearer token, read straight from the verified token claims. Used by clients to validate a stored token on startup.",
                "tags": [
                    "auth"
                ],
                "summary": "Get the current user",
                "responses": {
                    "200": {
                        "description": "The authenticated user",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/api.User"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Missing or invalid token",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/logs": {
            "get": {
                "description": "Returns the non-deleted water logs whose logged_at falls within the half-open range [from, to). The client passes the start of the selected local day and the start of the following day so day boundaries honour the client's timezone. Used to view historical days that are not cached locally.",
                "tags": [
                    "logs"
                ],
                "summary": "Fetch water logs for a specific day",
                "parameters": [
                    {
                        "description": "ISO-8601 timestamp marking the inclusive start of the range",
                        "name": "from",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "ISO-8601 timestamp marking the exclusive end of the range",
                        "name": "to",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logs within the requested range, most recent first",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/api.LogsResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Missing or invalid range parameters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server or database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/settings": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns the user's saved UI settings document (bottle size, daily goal, schedule, reminder). Responds 404 when the account has no settings yet, so the client keeps its local fallback values.",
                "tags": [
                    "settings"
                ],
                "summary": "Get the current user's UI settings",
                "responses": {
                    "200": {
                        "description": "The user's saved settings document",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/api.UserSettings"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Missing or invalid token",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "No settings saved for this user yet",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server or database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Upserts the user's UI settings document (stored verbatim as JSON). Creates the row on first save.",
                "tags": [
                    "settings"
                ],
                "summary": "Save the current user's UI settings",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/api.UserSettings"
                            }
                        }
                    },
                    "description": "The settings document to save",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "The saved settings document",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/api.UserSettings"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Missing or invalid token",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server or database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/sync": {
            "post": {
                "description": "Pushes local changes (upserts) to the server and pulls remote changes (delta) made on other devices.",
                "tags": [
                    "sync"
                ],
                "summary": "Sync local water logs with the server",
                "parameters": [
                    {
                        "description": "ISO-8601 Timestamp of the client's last sync",
                        "name": "since",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/api.WaterLog"
                                }
                            }
                        }
                    },
                    "description": "Array of local water logs to sync",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful sync response containing delta changes",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/api.SyncResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server or database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "/"
        }
    ],
    "components": {
        "securitySchemes": {
            "BearerAuth": {
                "description": "Type \"Bearer\" followed by a space and the session token issued by the identity service (id.ducktvt.com, POST /v1/auth/verify-code).",
                "type": "apiKey",
                "name": "Authorization",
                "in": "header"
            }
        },
        "schemas": {
            "api.LogsResponse": {
                "type": "object",
                "required": [
                    "logs"
                ],
                "properties": {
                    "logs": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/api.WaterLog"
                        }
                    }
                }
            },
            "api.SyncResponse": {
                "type": "object",
                "required": [
                    "changes",
                    "server_time"
                ],
                "properties": {
                    "changes": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/api.WaterLog"
                        }
                    },
                    "server_time": {
                        "type": "string"
                    }
                }
            },
            "api.User": {
                "type": "object",
                "required": [
                    "email",
                    "id"
                ],
                "properties": {
                    "email": {
                        "type": "string"
                    },
                    "id": {
                        "type": "string"
                    }
                }
            },
            "api.UserSettings": {
                "type": "object",
                "required": [
                    "settings"
                ],
                "properties": {
                    "settings": {
                        "type": "object"
                    }
                }
            },
            "api.WaterLog": {
                "type": "object",
                "required": [
                    "amount_ml",
                    "id",
                    "is_deleted",
                    "logged_at"
                ],
                "properties": {
                    "amount_ml": {
                        "type": "integer"
                    },
                    "id": {
                        "type": "string"
                    },
                    "is_deleted": {
                        "type": "boolean"
                    },
                    "logged_at": {
                        "type": "string"
                    }
                }
            }
        }
    }
}