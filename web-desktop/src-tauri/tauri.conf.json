{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Drinkwater",
  "version": "0.2.1",
  "identifier": "com.ducktivity.drinkwater",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Drinkwater",
        "width": 420,
        "height": 760,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ducktivity/drinkwater/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEMDNBQTg1OEQ2RjlCQzUKUldURm0yK05oYW9EUFVnNlNvREVRMkRlNzRJSTNaNTFOYnZQQzFCNGk3clhXb0pSU0Q1VXA2YUcK"
    }
  }
}
