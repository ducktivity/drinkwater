# Web app build-time configuration. Copy to `.env.local` for local overrides (`.env.local` is git-ignored). Only VITE_-prefixed vars are exposed to the client bundle.

# Base URL of the Drinkwater backend API.
# - Local dev: leave unset — the code defaults to http://localhost:8001.
# - Production (Cloudflare Pages): set to the backend's Cloudflare hostname, e.g. https://drinkwater-api.<yourdomain>. In CI this is injected from the GitHub repo variable VITE_API_BASE_URL, not from this file.
VITE_API_BASE_URL=

# Base URL of the shared identity service (the suite-wide auth issuer), used for passwordless login (POST /v1/auth/request-code and /v1/auth/verify-code).
# - Local dev: leave unset — the code defaults to http://localhost:8000.
# - Production (Cloudflare Pages): set to the identity hostname, e.g. https://id.<yourdomain>. In CI this is injected from the GitHub repo variable VITE_IDENTITY_BASE_URL, not from this file.
VITE_IDENTITY_BASE_URL=
