# Web app build-time configuration. Copy to `.env.local` for local overrides
# (`.env.local` is git-ignored). Only VITE_-prefixed vars are exposed to the
# client bundle.

# Base URL of the Drinkwater backend API.
# - Local dev: leave unset — the code defaults to http://localhost:8080.
# - Production (Cloudflare Pages): set to the backend's Cloudflare hostname,
#   e.g. https://drinkwater-api.<yourdomain>. In CI this is injected from the
#   GitHub repo variable VITE_API_BASE_URL, not from this file.
VITE_API_BASE_URL=
