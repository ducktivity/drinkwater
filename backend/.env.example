# Copy to .env and fill in. docker-compose reads this file automatically on production.

ENV=prod                        # prod | staging | development; tags every log + Sentry event
DATABASE_URL=postgres://postgres:postgres@localhost:5432/drinkwater?sslmode=disable
SENTRY_DSN=                     # empty disables Sentry (no-op); set to your project DSN in prod

# ---- Auth (passwordless email-OTP login) ----

AUTH_JWT_SECRET=                # REQUIRED outside dev: long random string; signs session JWTs + peppers login codes
RESEND_API_KEY=                 # Resend API key; empty (dev) logs login codes instead of emailing them
AUTH_EMAIL_FROM=Drinkwater <login@yourdomain>  # From header for login emails (must be a verified Resend domain in prod)

# ---- Cloudflare Tunnel (cloudflared only; the prod box's sole ingress) ----

CLOUDFLARE_TUNNEL_TOKEN=        # token from the named tunnel in Cloudflare Zero Trust (prod only; dev does not run the tunnel)

# ---- Log shipper (Vector only; the Go app never sees these) ----
BETTERSTACK_SOURCE_TOKEN=       # source's ingesting/source token from BetterStack
BETTERSTACK_INGEST_HOST=        # your source's ingesting host
